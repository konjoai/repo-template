# --- OS / editor cruft -------------------------------------------------
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
!.vscode/extensions.json

# --- Secrets / local env -------------------------------------------------
.env
.env.*
!.env.example

# --- Rust -----------------------------------------------------------------
# Generated by Cargo
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants — mutation testing data
**/mutants.out*/

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# --- Node / TypeScript -------------------------------------------------
node_modules/
dist/
*.tsbuildinfo
npm-debug.log*

# --- Konjo Quality Framework ---------------------------------------------
dry_report.json
mutation_report.txt
lcov.info
